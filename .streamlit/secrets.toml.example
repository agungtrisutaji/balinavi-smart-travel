# Contoh konfigurasi Streamlit secrets untuk BaliNavi.
# Salin file ini menjadi `secrets.toml` (di folder .streamlit/) lalu isi API key kamu.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# File secrets.toml sudah di-ignore oleh git, jadi API key tidak akan ikut ter-commit.
#
# API key dipakai hanya untuk mengambil foto tempat lewat Google Places API
# (Text Search v1). Disarankan me-restrict key hanya untuk Places API.

GOOGLE_API_KEY = "ISI_API_KEY_GOOGLE_PLACES_KAMU"
