# Contoh konfigurasi Streamlit secrets untuk BaliNavi.
# Salin file ini menjadi `secrets.toml` di folder `.streamlit/`.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# File `.streamlit/secrets.toml` sudah di-ignore oleh git, jadi nilai
# rahasia tidak akan ikut ter-commit.
#
# BACKEND_URL dipakai frontend untuk memanggil FastAPI backend.
# GOOGLE_API_KEY opsional, dipakai hanya untuk mengambil foto tempat lewat
# Google Places API (Text Search v1). Jika kosong, aplikasi tetap berjalan
# dengan gambar dari dataset/placeholder.

BACKEND_URL = "http://localhost:8000"
GOOGLE_API_KEY = ""
